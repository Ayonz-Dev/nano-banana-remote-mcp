# Copy to .env for local testing (never commit the real .env)
GEMINI_API_KEY=your-gemini-key-here
# Optional shared secret; if set, the connector must send Authorization: Bearer <token>
MCP_AUTH_TOKEN=choose-a-long-random-string
# Optional model override
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Local port (hosts usually set PORT automatically)
PORT=8080

# Dropbox auto-save (optional). If all three are set, generated images upload to Dropbox.
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=run get-dropbox-refresh-token.mjs to obtain this
DROPBOX_DEST_PATH=/Pictures/Nano Banana
